{
  "language": "ru",
  "sample_rate": 16000,
  "listen_seconds": 6,

  "vosk_models": {
    "ru": "models/ru",
    "kz": "models/kz"
  },

  "tts_engine": "silero",
  "tts_rate": 170,

  "tts_voice_ru": "baya_v2",
  "tts_voice_kz": "aigul_v2",

  "tts_silero": {
    "device": "cpu",
    "sample_rate": 24000,
    "cache_dir": "models/tts_cache"
  },

  "prompts": {
    "ru": {
      "boot": "Голосовой помощник запущен. Нажмите Enter и говорите.",
      "listening": "Слушаю.",
      "bye": "Завершаю работу. До свидания.",
      "unknown": "Не понял. Скажите: помощь.",
      "switched_ok": "Переключился на русский.",
      "model_not_found": "Модель для этого языка не найдена.",
      "switch_failed": "Не удалось переключить язык. Проверьте папку модели."
    },
    "kz": {
      "boot": "Дауыс көмекші іске қосылды. Enter басып, сөйлеңіз.",
      "listening": "Тыңдап тұрмын.",
      "bye": "Жұмысты аяқтаймын. Сау болыңыз.",
      "unknown": "Түсінбедім. Айтыңыз: көмек.",
      "switched_ok": "Қазақ тіліне ауыстым.",
      "model_not_found": "Бұл тілге модель табылмады.",
      "switch_failed": "Тілді ауыстыру мүмкін болмады. Модель папкасын тексеріңіз."
    }
  },

  "notes_file": "notes.txt",

  "sos": {
    "local_alarm": true,
    "speak_alarm_text": "Нужна помощь! SOS активирован!",
    "telegram_enabled": false,
    "telegram_bot_token": "PUT_TOKEN_HERE",
    "telegram_chat_id": "PUT_CHAT_ID_HERE",
    "telegram_message": "SOS! Нужна помощь. Команда помощи активирована голосовым помощником."
  },

  "llm": {
    "enabled": true,
    "base_url": "http://localhost:11434",
    "model": "qwen2.5:3b",
    "timeout_seconds": 25,
    "allowed_intents": [
      "help",
      "time",
      "date",
      "reminder",
      "read_clipboard",
      "note",
      "sos",
      "switch_lang",
      "exit",
      "chat",
      "unknown"
    ]
  }
}